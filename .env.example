# hervoice 配置 — 复制为 .env 填写，别把 .env 提交进 git

# 转写：Groq Whisper（免费额度足够个人用）https://console.groq.com
GROQ_API_KEY=

# 情感分析 LLM：任何 OpenAI 兼容接口都行（默认 DeepSeek，便宜）
# 想都用 Groq 一个账号的话，把 LLM_BASE_URL 改成 https://api.groq.com/openai/v1，
# LLM_API_KEY 填 GROQ_API_KEY 同一个值，LLM_MODEL 换成 Groq 上的模型名即可。
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 转写模型和语言
WHISPER_MODEL=whisper-large-v3
WHISPER_LANG=zh

# 数据目录：SQLite 数据库（消息+回复，永久保存）和可选音频都存这里
HERVOICE_DATA=./data

# 是否留存音频。默认 0 = 阅后即焚（只留文字和情感分析结果）。
# 设 1 = 保留 mp3，可通过 /api/voice/audio/<name> 重听。留存是隐私决定，自己权衡。
KEEP_AUDIO=0

# ── 网页录音入口登录（HTTP Basic Auth，务必配 HTTPS 反代再用）──
WEB_USERNAME=
WEB_PASSWORD=

# ── voice_mcp.py：Claude Code 拉取语音信箱用的 MCP server ──
# MCP_TOKEN 必填，Claude Code 那边连接时要在 Authorization: Bearer <token> 里带上同样的值
MCP_TOKEN=
MCP_HOST=0.0.0.0
MCP_PORT=8020
